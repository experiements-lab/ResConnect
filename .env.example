# ── Backend ───────────────────────────────────────────────────────────────────

# Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase service_role key — keep secret, never expose to browser
# (Settings > API > Project API keys > service_role)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret for verifying user tokens
# (Settings > API > JWT Settings > JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Supabase Postgres connection string (Transaction pooler recommended for Railway)
# (Settings > Database > Connection string > Transaction)
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-xx-X.pooler.supabase.com:6543/postgres

# Admin key — protect the /admin panel (set any strong random string)
SECRET_KEY=change_me_in_production

# Comma-separated allowed CORS origins (no trailing slash)
CORS_ORIGINS=https://resconnect.co.za,https://www.resconnect.co.za

# ── Frontend (Vercel env vars) ────────────────────────────────────────────────

# Supabase project URL (same as above — safe to expose)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase anon/public key — safe to expose to browser
# (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL of the deployed FastAPI backend
VITE_API_URL=https://api.resconnect.co.za
