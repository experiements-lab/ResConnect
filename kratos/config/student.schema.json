{
  "$id": "https://resconnect.co.za/schemas/student.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Student",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "pattern": "^[a-zA-Z0-9._%+\\-]+@sun\\.ac\\.za$",
          "title": "SU Email Address",
          "ory.sh/kratos": {
            "credentials": {
              "password": { "identifier": true }
            },
            "verification": { "via": "email" },
            "recovery": { "via": "email" }
          }
        },
        "full_name": {
          "type": "string",
          "title": "Full Name",
          "minLength": 2,
          "maxLength": 255
        },
        "student_number": {
          "type": "string",
          "title": "Student Number",
          "pattern": "^[0-9]{8}$"
        },
        "role": {
          "type": "string",
          "title": "Role",
          "const": "student"
        }
      },
      "required": ["email", "full_name", "student_number"],
      "additionalProperties": false
    }
  }
}
