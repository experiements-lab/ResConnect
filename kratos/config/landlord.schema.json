{
  "$id": "https://resconnect.co.za/schemas/landlord.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Landlord",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "Email Address",
          "ory.sh/kratos": {
            "credentials": {
              "password": { "identifier": true }
            },
            "verification": { "via": "email" },
            "recovery": { "via": "email" }
          }
        },
        "full_name": {
          "type": "string",
          "title": "Full Name",
          "minLength": 2,
          "maxLength": 255
        },
        "phone": {
          "type": "string",
          "title": "Phone Number"
        },
        "role": {
          "type": "string",
          "title": "Role",
          "const": "landlord"
        }
      },
      "required": ["email", "full_name", "phone"],
      "additionalProperties": false
    }
  }
}
